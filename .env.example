# Необязательный серверный ключ OpenRouter.
# Если задан, пользователям не нужно вводить собственный ключ в интерфейсе.
# Получить бесплатно: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Модель по умолчанию для генерации писем нейросетью.
OPENROUTER_DEFAULT_MODEL=openai/gpt-oss-20b:free

# Разрешённые источники CORS (через запятую в JSON-формате при необходимости).
# CORS_ORIGINS=["*"]
